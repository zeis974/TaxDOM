{
  "name": "@taxdom/api",
  "private": true,
  "type": "module",
  "license": "AGPL-3.0-only",
  "exports": {
    "./data": "./.adonisjs/client/data.d.ts",
    "./registry": "./.adonisjs/client/registry/index.ts"
  },
  "scripts": {
    "start": "node bin/server.js",
    "build": "node ace build",
    "dev": "node ace serve --hmr",
    "typecheck": "tsc --noEmit",
    "db:generate": "pnpm dlx auth generate --config config/auth.ts --output database/auth-schema.ts --y",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push"
  },
  "imports": {
    "#controllers/*": "./app/controllers/*.js",
    "#exceptions/*": "./app/exceptions/*.js",
    "#models/*": "./app/models/*.js",
    "#mails/*": "./app/mails/*.js",
    "#services/*": "./app/services/*.js",
    "#lib/*": "./app/lib/*.js",
    "#listeners/*": "./app/listeners/*.js",
    "#events/*": "./app/events/*.js",
    "#middleware/*": "./app/middleware/*.js",
    "#validators/*": "./app/validators/*.js",
    "#providers/*": "./providers/*.js",
    "#policies/*": "./app/policies/*.js",
    "#abilities/*": "./app/abilities/*.js",
    "#database/*": "./database/*.js",
    "#start/*": "./start/*.js",
    "#tests/*": "./tests/*.js",
    "#types/*": "./types/*.js",
    "#config/*": "./config/*.js",
    "#generated/*": "./.adonisjs/server/*.js"
  },
  "dependencies": {
    "@adonisjs/core": "7.3.0",
    "@adonisjs/cors": "3.0.0",
    "@adonisjs/limiter": "3.0.1",
    "@adonisjs/redis": "10.0.0",
    "@adonisjs/session": "8.0.0",
    "@adonisjs/shield": "9.0.0",
    "@better-auth/drizzle-adapter": "1.5.6",
    "@vinejs/vine": "4.3.0",
    "better-auth": "1.6.1",
    "drizzle-orm": "0.45.2",
    "luxon": "3.7.2",
    "pg": "8.20.0",
    "reflect-metadata": "0.2.2",
    "uuid": "13.0.0"
  },
  "devDependencies": {
    "@adonisjs/assembler": "8.4.0",
    "@adonisjs/tsconfig": "2.0.0",
    "@poppinss/ts-exec": "1.4.4",
    "@taxdom/types": "workspace:*",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "0.31.10",
    "hot-hook": "1.0.0",
    "pino-pretty": "13.1.3",
    "typescript": "5.9.3",
    "youch": "4.1.1"
  },
  "hotHook": {
    "boundaries": [
      "./app/controllers/**/*.ts",
      "./app/middleware/*.ts"
    ]
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.33.0"
}
