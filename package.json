{
  "name": "taxdom",
  "author": "zeis974 <hi@zeis.dev>",
  "description": "A modern tax calculation application for French overseas departments and regions",
  "license": "AGPL-3.0-only",
  "scripts": {
    "prepare": "husky",
    "dev": "turbo run dev",
    "dev:api": "pnpm --filter @taxdom/api dev",
    "dev:blog": "pnpm --filter @taxdom/blog dev",
    "dev:dashboard": "pnpm --filter @taxdom/dashboard dev",
    "dev:db": "docker compose -f compose.dev.yml up -d --build db",
    "dev:web": "pnpm --filter @taxdom/app dev",
    "build": "turbo run build",
    "format": "biome format . --write",
    "design:lint": "pnpx @google/design.md lint DESIGN.md"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "turbo": "2.10.0",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=11"
  },
  "packageManager": "pnpm@11.9.0",
  "lint-staged": {
    "*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
      "biome format --write --no-errors-on-unmatched"
    ]
  }
}